```gitignore
# =========================================================
# PYTHON
# =========================================================
__pycache__/
*.py[cod]
*$py.class

venv/
.venv/
env/
ENV/

# =========================================================
# BUILD / DISTRIBUTION
# =========================================================
build/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/

*.egg
*.egg-info/
.installed.cfg

# =========================================================
# LOGS
# =========================================================
*.log

# =========================================================
# ENVIRONMENT / SECRETS
# =========================================================
.env
.env.*
*.env

# =========================================================
# API / SECRET / CONFIG FILES
# =========================================================
**/api_keys.json
**/secrets.json
**/config.local.json

**/*secret*.json
**/*token*.json
**/*key*.json
**/*credential*.json

# =========================================================
# MEMORY / USER DATA
# =========================================================
memory/
memory/*.json

# =========================================================
# DATABASE
# =========================================================
*.db
*.sqlite
*.sqlite3

# =========================================================
# IDE / EDITOR
# =========================================================
.vscode/
.idea/

*.suo
*.user
*.userosscache
*.sln.docstates

# =========================================================
# OPERATING SYSTEM FILES
# =========================================================
.DS_Store
Thumbs.db
desktop.ini

# =========================================================
# AI / TOOLING
# =========================================================
.claude/

# =========================================================
# SWIFT CACHE
# =========================================================
.swift-cache/
.swift-home/

# =========================================================
# NODE.JS
# =========================================================
node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================================================
# TEMPORARY FILES
# =========================================================
tmp/
temp/

*.tmp
*.bak
*.swp

# =========================================================
# GENERATED / OUTPUT FILES
# =========================================================
recordings/
voices/
output/
generated/

# =========================================================
# JUPYTER
# =========================================================
.ipynb_checkpoints/

# =========================================================
# TESTING
# =========================================================
.pytest_cache/
.coverage
htmlcov/

# =========================================================
# TYPE CHECKING / LINT CACHE
# =========================================================
.mypy_cache/
.pyre/
.ruff_cache/

# =========================================================
# AI MODELS / WEIGHTS
# =========================================================
models/
checkpoints/
weights/

*.onnx
*.pt
*.pth

# =========================================================
# DOCKER
# =========================================================
.docker/
docker-compose.override.yml

# =========================================================
# CERTIFICATES / PRIVATE KEYS
# =========================================================
*.pem
*.key
*.crt
*.p12
```